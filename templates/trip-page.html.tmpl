<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{TITLE}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://images.unsplash.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      color: #1a1a2e;
      background: #faf9f7;
      line-height: 1.7;
      touch-action: manipulation;
    }
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; font-weight: 600; }

    .hero {
      position: relative;
      height: 100vh;
      min-height: 600px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: #fff;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0.55) 70%, rgba(0,0,0,0.75) 100%);
      z-index: 1;
    }
    .hero-video {
      position: absolute;
      top: 50%; left: 50%;
      width: 100%; height: 100%;
      object-fit: cover;
      transform: translate(-50%, -50%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 800px;
      padding: 0 24px;
    }
    .hero-content h1 {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 600;
      letter-spacing: 2px;
      margin-bottom: 0.3em;
    }
    .hero-content .sub {
      font-size: clamp(1rem, 2.5vw, 1.4rem);
      font-weight: 300;
      opacity: 0.9;
      letter-spacing: 4px;
      text-transform: uppercase;
      margin-bottom: 1.5em;
    }
    .hero-content .date {
      font-size: 1.05rem;
      opacity: 0.8;
      border-top: 1px solid rgba(255,255,255,0.3);
      padding-top: 1.5em;
      display: inline-block;
    }
    .scroll-indicator {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      color: #fff;
      font-size: 0.8rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      opacity: 0.7;
      animation: bounce 2s infinite;
    }
    @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(250,249,247,0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid #e8e3dd;
      padding: 0 24px;
    }
    nav ul {
      list-style: none;
      display: flex;
      justify-content: center;
      gap: 4px;
      max-width: 1000px;
      margin: 0 auto;
      overflow-x: auto;
      padding: 0;
    }
    nav li a {
      display: block;
      padding: 14px 18px;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
      text-decoration: none;
      color: #555;
      white-space: nowrap;
      transition: color 0.2s;
    }
    nav li a:hover { color: #b8865b; }

    section { max-width: 1100px; margin: 0 auto; padding: 70px 24px; scroll-margin-top: 60px; }
    .section-title {
      text-align: center;
      margin-bottom: 40px;
    }
    .section-title h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      color: #1a1a2e;
      text-wrap: balance;
    }
    .section-title p {
      color: #777;
      font-size: 1rem;
      margin-top: 8px;
    }
    .section-title::after {
      content: '';
      display: block;
      width: 50px;
      height: 2px;
      background: #b8865b;
      margin: 16px auto 0;
    }

    .timeline-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-top: 10px;
    }
    .timeline-card {
      background: #fff;
      border-radius: 12px;
      padding: 28px 20px;
      text-align: center;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      border: 1px solid #eeeae4;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .timeline-card:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(0,0,0,0.07); }
    .timeline-card .days { font-size: 0.8rem; color: #b8865b; letter-spacing: 2px; text-transform: uppercase; font-weight: 600; }
    .timeline-card h3 { font-size: 1.25rem; margin: 8px 0; }
    .timeline-card p { font-size: 0.9rem; color: #666; }

    .area-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
    }
    .area-header .num {
      flex-shrink: 0;
      width: 52px; height: 52px;
      border-radius: 50%;
      background: #b8865b;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
    }
    .area-header h2 { margin-bottom: 2px; }
    .area-header p { color: #888; font-size: 0.9rem; }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } }

    .info-card {
      background: #fff;
      border-radius: 14px;
      padding: 24px;
      border: 1px solid #eeeae4;
      margin-bottom: 20px;
    }
    .info-card h3 {
      font-size: 1.15rem;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .info-card ul { list-style: none; }
    .info-card li {
      padding: 6px 0;
      font-size: 0.92rem;
      color: #444;
      border-bottom: 1px solid #f5f2ed;
    }
    .info-card li:last-child { border: none; }
    .info-card li .label { font-weight: 500; color: #1a1a2e; }
    .info-card li .price { color: #b8865b; font-weight: 500; }
    .info-card li .sep { color: #ccc; margin: 0 6px; }

    .img-banner {
      width: 100%;
      height: 240px;
      border-radius: 14px;
      object-fit: cover;
      margin-bottom: 20px;
    }

    .hotel-card {
      background: #fff;
      border-radius: 14px;
      border: 1px solid #eeeae4;
      overflow: hidden;
      margin-bottom: 12px;
      display: flex;
      gap: 0;
      transition: box-shadow 0.2s;
    }
    .hotel-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .hotel-card-img {
      width: 130px;
      min-height: 130px;
      flex-shrink: 0;
      object-fit: cover;
    }
    .hotel-card-body {
      padding: 14px 16px;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .hotel-card-body .name-row {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 3px;
    }
    .hotel-card-body .name-row h4 { font-size: 0.95rem; font-weight: 600; }
    .rating-badge {
      display: inline-flex;
      align-items: center;
      gap: 2px;
      background: #1a1a2e;
      color: #fff;
      font-size: 0.68rem;
      font-weight: 600;
      padding: 2px 7px;
      border-radius: 4px;
    }
    .rating-badge .star { color: #f5c842; font-size: 0.55rem; }
    .platform-badge {
      display: inline-block;
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      padding: 2px 7px;
      border-radius: 3px;
      background: #e8f0fe;
      color: #1a73e8;
    }
    .platform-badge.agoda { background: #fef3e2; color: #e67e22; }
    .hotel-card-body .price-line { font-size: 0.88rem; margin: 2px 0 3px; }
    .hotel-card-body .price-line .price { font-weight: 600; color: #b8865b; font-size: 1rem; }
    .hotel-card-body .features {
      display: flex;
      flex-wrap: wrap;
      gap: 3px;
      margin: 3px 0;
    }
    .hotel-card-body .features span {
      font-size: 0.65rem;
      background: #f5f2ed;
      padding: 2px 7px;
      border-radius: 4px;
      color: #555;
    }
    .hotel-card-body .desc { font-size: 0.8rem; color: #666; margin-top: 2px; }
    .hotel-card-body .couples-note { font-size: 0.72rem; color: #b8865b; margin-top: 2px; }
    @media (max-width: 600px) {
      .hotel-card { flex-direction: column; }
      .hotel-card-img { width: 100%; height: 110px; }
    }

    .tip-box {
      background: #fdf8f3;
      border-left: 3px solid #b8865b;
      border-radius: 8px;
      padding: 12px 16px;
      margin-top: 14px;
      font-size: 0.85rem;
      color: #555;
    }
    .tip-box strong { color: #1a1a2e; }

    .spot-card {
      display: flex;
      gap: 12px;
      background: #fff;
      border-radius: 12px;
      border: 1px solid #eeeae4;
      overflow: hidden;
      margin-bottom: 12px;
      transition: box-shadow 0.2s;
    }
    .spot-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .spot-card-img {
      width: 110px;
      min-height: 110px;
      flex-shrink: 0;
      object-fit: cover;
    }
    .spot-card-body { padding: 12px 14px; flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .spot-card-body h4 { font-size: 0.95rem; font-weight: 600; margin-bottom: 2px; }
    .spot-card-body .vibe {
      font-size: 0.82rem;
      color: #888;
      font-style: italic;
      margin-bottom: 4px;
    }
    .spot-card-body .detail {
      font-size: 0.82rem;
      color: #555;
    }
    .spot-card-body .price-tag {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 600;
      color: #b8865b;
      background: #fdf8f3;
      padding: 2px 8px;
      border-radius: 4px;
      margin-top: 4px;
    }
    @media (max-width: 600px) {
      .spot-card { flex-direction: column; }
      .spot-card-img { width: 100%; height: 110px; }
    }

    .budget-table-wrap { overflow-x: auto; margin-top: 10px; }
    .budget-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.92rem;
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
      border: 1px solid #eeeae4;
    }
    .budget-table thead { background: #1a1a2e; color: #fff; }
    .budget-table th {
      padding: 16px 20px;
      text-align: left;
      font-weight: 500;
      font-size: 0.85rem;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .budget-table td {
      padding: 14px 20px;
      border-bottom: 1px solid #f0ece6;
    }
    .budget-table tbody tr:last-child td { border: none; }
    .budget-table tfoot { background: #f8f5f0; font-weight: 600; }
    .budget-table tfoot td { padding: 16px 20px; }
    .budget-table .num-col { text-align: right; font-variant-numeric: tabular-nums; }
    .budget-table .total-row td { border-top: 2px solid #b8865b; }
    .budget-note { text-align: center; color: #888; font-size: 0.85rem; margin-top: 20px; }

    footer {
      text-align: center;
      padding: 60px 24px 40px;
      color: #999;
      font-size: 0.85rem;
      border-top: 1px solid #eeeae4;
      max-width: 1100px;
      margin: 0 auto;
    }
    footer .hearts { font-size: 1.3rem; }

    @media (max-width: 600px) {
      section { padding: 50px 16px; }
      .info-card { padding: 18px; }
      nav li a { padding: 12px 10px; font-size: 0.7rem; }
    }

    /* ── Day-by-day section ──────────────────────────────────────────── */
    #dayplan .dayplan-controls { display: flex; gap: 12px; justify-content: center; margin-bottom: 32px; flex-wrap: wrap; }
    #dayplan .dayplan-controls button { background: #fff; border: 1px solid #d4cfc7; color: #1a1a2e; padding: 8px 16px; border-radius: 999px; font-family: inherit; font-size: .9rem; cursor: pointer; transition: background .15s; }
    #dayplan .dayplan-controls button:hover { background: #f0ebe3; }
    .day-grid { display: grid; grid-template-columns: 1fr; gap: 16px; max-width: 900px; margin: 0 auto; }
    @media (min-width: 900px) { .day-grid { grid-template-columns: 1fr 1fr; } }
    .day-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.06); padding: 18px 20px; display: flex; flex-direction: column; gap: 12px; }
    .day-card-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
    .day-num { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: #b8865b; letter-spacing: 1px; }
    .day-tags { display: flex; gap: 8px; }
    .region-tag, .status-badge { font-size: .75rem; letter-spacing: 1px; text-transform: uppercase; padding: 3px 10px; border-radius: 999px; }
    .region-tag { background: #f0ebe3; color: #1a1a2e; }
    .status-badge { color: #fff; }
    .day-card-active .status-badge { background: #2e8b57; }
    .day-card-rest   .status-badge { background: #b8865b; }
    .day-card-transfer .status-badge { background: #6b7a8f; }
    .day-card-activity, .day-card-dinner { font-size: .95rem; }
    .day-card-activity .muted, .day-card-dinner .muted { color: #888; font-size: .85rem; }
    .day-card .swap-btn { background: none; border: none; color: #b8865b; font: inherit; cursor: pointer; padding: 4px 0; text-decoration: underline; display: block; margin-top: 6px; }
    .swap-pool { display: none; margin-top: 8px; padding: 8px; background: #faf6f0; border-radius: 6px; max-height: 240px; overflow-y: auto; }
    .swap-pool.open { display: block; }
    .swap-pool .swap-option { display: flex; gap: 10px; padding: 6px; cursor: pointer; border-radius: 4px; }
    .swap-pool .swap-option:hover { background: #f0ebe3; }
    .rest-suggestion, .transfer-note { color: #555; font-style: italic; }

    /* ── Local quote callout ─────────────────────────────────────────── */
    .local-quote { font-family: 'Playfair Display', serif; font-style: italic; border-left: 3px solid #b8865b; padding: 12px 16px; margin-top: 16px; color: #555; background: #faf6f0; border-radius: 0 8px 8px 0; }
    .local-quote cite { display: block; font-style: normal; font-family: 'Inter', sans-serif; font-size: .8rem; color: #888; margin-top: 6px; letter-spacing: 1px; }

    /* ── Social embeds ───────────────────────────────────────────────── */
    .social-embeds { margin-top: 16px; }
    .social-embeds summary { cursor: pointer; font-size: .9rem; color: #b8865b; padding: 6px 0; }
    .social-embeds[open] { max-height: 600px; overflow-y: auto; }

    /* ── Print stylesheet ────────────────────────────────────────────── */
    @media print {
      nav, .hero-video, .hero, .scroll-indicator, .social-embeds, .swap-btn, .dayplan-controls { display: none !important; }
      body { background: #fff; padding: 0 12mm; font-size: 11pt; }
      .day-card { page-break-inside: avoid; box-shadow: none; border: 1px solid #ccc; margin-bottom: 6mm; }
      .img-banner, .trip-hero { display: none; }
      h1, h2 { color: #000; }
    }
  </style>
</head>
<body>

<header class="hero">
  <img
    class="hero-video"
    src="{{HERO_IMG}}"
    alt="{{TITLE}}"
    width="1920" height="1080"
    fetchpriority="high"
  >
  <div class="hero-content">
    <p class="sub">{{SUBTITLE}}</p>
    <h1>{{TITLE}}</h1>
    <span class="date">{{DATES_LONG}}</span>
  </div>
  <div class="scroll-indicator">Scroll</div>
</header>

<nav>
  <ul>
    {{NAV_LINKS}}
  </ul>
</nav>

<section id="overview">
  <div class="section-title">
    <h2>{{OVERVIEW_TITLE}}</h2>
    <p>{{OVERVIEW_TAGLINE}}</p>
  </div>
  <div class="timeline-grid">
    {{TIMELINE_CARDS}}
  </div>
  <div style="text-align:center;margin-top:32px;color:#888;font-size:0.92rem;">
    {{WEATHER_NOTE}}
  </div>
</section>

<section id="dayplan">
  <div class="section-title">
    <h2>Day-by-Day</h2>
    <p>Paced to give you energy &mdash; one thing per active day, rest in between</p>
  </div>
  <div class="dayplan-controls">
    <button id="plan-reset" type="button">Reset</button>
    <button id="plan-shuffle" type="button">Shuffle</button>
    <button id="plan-print" type="button">Print</button>
  </div>
  <div class="day-grid">
    {{DAY_PLAN_SECTION}}
  </div>
</section>

{{REGION_SECTIONS}}


<section id="budget">
  <div class="section-title">
    <h2>Budget Estimation</h2>
    <p>{{BUDGET_TAGLINE}}</p>
  </div>
  <div class="budget-table-wrap">
    <table class="budget-table">
      <thead>
        <tr><th>Category</th><th>Details</th><th class="num-col">Est. Cost (USD)</th></tr>
      </thead>
      <tbody>
        {{BUDGET_TABLE}}
      </tbody>
    </table>
  </div>
  <p class="budget-note">{{BUDGET_NOTE}}</p>
</section>

<footer>
  <div class="hearts">&hearts; &hearts; &hearts;</div>
  <p style="margin-top:8px;">{{FOOTER_CLOSING}}</p>
  <p style="margin-top:4px;">Made with love for our honeymoon planning</p>
</footer>

<template id="fragments" hidden>
<!-- NAV_ITEM_TEMPLATE_START -->
<li><a href="#{{ITEM_ID}}">{{ITEM_LABEL}}</a></li>
<!-- NAV_ITEM_TEMPLATE_END -->

<!-- TIMELINE_CARD_TEMPLATE_START -->
<div class="timeline-card">
  <div class="days">Days {{REGION_DAYS}}</div>
  <h3>{{REGION_NAME}}</h3>
  <p>{{REGION_TAGLINE}}</p>
</div>
<!-- TIMELINE_CARD_TEMPLATE_END -->

<!-- HOTEL_CARD_TEMPLATE_START -->
<div class="hotel-card">
  <img class="hotel-card-img" src="{{HOTEL_IMG}}" alt="{{HOTEL_NAME}}" loading="lazy" width="130" height="130">
  <div class="hotel-card-body">
    <div class="name-row">
      <h4>{{HOTEL_NAME}}</h4>
      <span class="rating-badge"><span class="star">&#9733;</span> {{HOTEL_RATING}}</span>
      <span class="platform-badge {{HOTEL_PLATFORM_CLASS}}">{{HOTEL_PLATFORM}}</span>
    </div>
    <div class="price-line">from <span class="price">{{HOTEL_PRICE}}</span> / night</div>
    <div class="features">{{HOTEL_FEATURES}}</div>
    <div class="desc">{{HOTEL_DESC}}</div>
    {{HOTEL_COUPLES_NOTE}}
  </div>
</div>
<!-- HOTEL_CARD_TEMPLATE_END -->

<!-- SPOT_CARD_TEMPLATE_START -->
<div class="spot-card">
  <img class="spot-card-img" src="{{SPOT_IMG}}" alt="{{SPOT_NAME}}" loading="lazy" width="110" height="110">
  <div class="spot-card-body">
    <h4>{{SPOT_NAME}}</h4>
    <div class="vibe">{{SPOT_VIBE}}</div>
    <div class="detail">{{SPOT_DETAIL}}</div>
    <span class="price-tag">{{SPOT_PRICE}}</span>
  </div>
</div>
<!-- SPOT_CARD_TEMPLATE_END -->

<!-- DAY_CARD_TEMPLATE_START -->
<article class="day-card day-card-{{STATUS}}" data-day="{{DAY_N}}" aria-label="Day {{DAY_N}}, {{STATUS}}, {{ACTIVITY_NAME_OR_REST}}">
  <header class="day-card-head">
    <div class="day-num">DAY {{DAY_N_PAD}} &middot; {{DATE_SHORT}}</div>
    <div class="day-tags"><span class="region-tag">{{REGION_NAME}}</span><span class="status-badge">{{STATUS_BADGE}}</span></div>
  </header>
  <div class="day-card-activity">{{ACTIVITY_BLOCK}}</div>
  <div class="day-card-dinner">{{DINNER_BLOCK}}</div>
</article>
<!-- DAY_CARD_TEMPLATE_END -->

<!-- REGION_SECTION_TEMPLATE_START -->
<section id="{{REGION_ID}}">
  <div class="area-header">
    <div class="num">{{REGION_NUM}}</div>
    <div>
      <h2>{{REGION_NAME}}</h2>
      <p>Days {{REGION_DAYS}} &middot; {{REGION_NIGHTS}} nights &middot; {{REGION_TAGLINE}}</p>
    </div>
  </div>
  <img class="img-banner" src="{{REGION_BANNER_IMG}}" alt="{{REGION_NAME}}" width="1100" height="240" loading="lazy">
  <div class="content-grid">
    <div>
      <div class="info-card">
        <h3>&#128666; Getting There</h3>
        <ul>{{GETTING_THERE_LIST}}</ul>
      </div>
      <div class="info-card">
        <h3>&#127968; Where to Stay</h3>
        {{HOTEL_CARDS}}
        {{HOTEL_TIP_BOX}}
      </div>
    </div>
    <div>
      <div class="info-card">
        <h3>&#128247; What to Visit in {{REGION_NAME}}</h3>
        {{ATTRACTION_CARDS}}
      </div>
      {{LOCAL_QUOTE_BOX}}
      {{SOCIAL_EMBEDS}}
    </div>
  </div>
</section>
<!-- REGION_SECTION_TEMPLATE_END -->
</template>

<script id="trip-data" type="application/json">
{{TRIP_DATA_JSON}}
</script>
<script>
{{SWAP_RUNTIME_JS}}
</script>

</body>
</html>
